@model IEnumerable<TrelloClone.Core.Entities.Project>

@{
    ViewData["Title"] = "Pano Görünümü";
}

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col">
            <h2>Projelerim</h2>
            <p class="text-muted">Trello Clone Yönetim Paneline Hoş Geldiniz.</p>
        </div>
        <div class="col text-end">
            <a href="/Board/CreateProject" class="btn btn-primary">+ Yeni Proje Oluştur</a>
        </div>
    </div>

    <div class="row">
        @if (Model != null && Model.Any())
        {
            foreach (var project in Model)
            {
                <div class="col-md-4 mb-3">
                    <div class="card shadow-sm h-100">
                        <div class="card-body">
                            <h5 class="card-title">@project.Name</h5>
                            <p class="card-text text-muted">@project.Description</p>
                        </div>
                        <div class="card-footer bg-white border-top-0">
                            <a href="/Board/Detail/@project.Id" class="btn btn-outline-success w-100">Panoya Git</a>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col">
                <div class="alert alert-warning" role="alert">
                    Henüz hiç proje oluşturmadınız. Lütfen yeni bir proje ekleyin.
                </div>
            </div>
        }
    </div>
</div>