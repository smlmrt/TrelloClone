@model TrelloClone.Core.Entities.Project

@{
    ViewData["Title"] = Model.Name + " Panosu";
}

<div class="container-fluid mt-4">
    <h2 class="mb-4">@Model.Name</h2>

    <div class="d-flex overflow-auto" style="gap: 1.5rem; padding-bottom: 1rem; align-items: flex-start;">
        
        @if(Model.Columns != null)
        {
            foreach (var column in Model.Columns.OrderBy(c => c.Order))
            {
                <div class="card bg-light border-0 shadow-sm" style="min-width: 320px; width: 320px;"
                     ondragover="allowDrop(event)" 
                     ondrop="drop(event, @column.Id)">
                    
                    <div class="card-header bg-transparent border-bottom-0 fw-bold pt-3 pb-1">
                        @column.Title
                    </div>
                    
                    <div class="card-body" id="column-@column.Id" style="min-height: 200px;">
                        @if(column.Cards != null)
                        {
                            foreach (var card in column.Cards.OrderBy(c => c.Order))
                            {
                                <div class="card mb-2 shadow-sm border-0" 
                                     id="card-@card.Id" 
                                     draggable="true" 
                                     ondragstart="drag(event, @card.Id)"
                                     style="cursor: grab;">
                                    <div class="card-body p-3">
                                        <h6 class="card-title mb-1">@card.Title</h6>
                                        <small class="text-muted">@card.Description</small>
                                    </div>
                                </div>
                            }
                        }
                    </div>
                    <div class="card-footer bg-transparent border-top-0">
                        <a href="/Board/CreateCard?columnId=@column.Id" class="btn btn-sm btn-outline-secondary w-100">+ Yeni Kart Ekle</a>
                    </div>
                </div>
            }
        }
    </div>
</div>
@section Scripts {
    <script>
        // 1. Sürüklenen öğenin üzerine gelindiğinde varsayılan davranışı iptal et (bırakmaya izin ver)
        function allowDrop(ev) {
            ev.preventDefault();
        }

        // 2. Kart sürüklenmeye başlandığında, kartın ID'sini hafızaya (dataTransfer) al
        function drag(ev, cardId) {
            ev.dataTransfer.setData("cardId", cardId);
        }

        // 3. Kart bir sütuna bırakıldığında çalışacak metot
        function drop(ev, newColumnId) {
            ev.preventDefault();
            
            // Hafızadaki kart ID'sini al
            var cardId = ev.dataTransfer.getData("cardId");
            var cardElement = document.getElementById("card-" + cardId);

            // Optimistic UI Update: Beklemeden arayüzde kartı yeni sütuna taşı (Kullanıcı deneyimi için)
            var dropTarget = ev.target.closest('.card-body');
            if(dropTarget) {
                dropTarget.appendChild(cardElement);
            }

            // AJAX (Fetch API) ile değişikliği C# Backend'ine bildir
            fetch('/Board/UpdateCardPosition', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify({ 
                    cardId: parseInt(cardId), 
                    newColumnId: newColumnId 
                })
            })
            .then(response => {
                if(!response.ok) {
                    alert("Kart taşınırken veritabanında bir hata oluştu!");
                    // Gerçek bir senaryoda hata olursa kartı eski yerine (DOM manipulation ile) geri koymalıyız.
                }
            })
            .catch(error => console.error('Hata:', error));
        }

        // Model.Id (Proje ID) değerini C#'tan alıp JS değişkenine atıyoruz
        var projectId = "@Model.Id"; 

        var connection = new signalR.HubConnectionBuilder().withUrl("/boardHub").build();

        // Sunucudan (C# Controller'dan) "ReceiveCardMove" mesajı geldiğinde tetiklenecek fonksiyon
        connection.on("ReceiveCardMove", function (cardId, newColumnId) {
            
            // Taşınan kartın HTML elementini bul
            var cardElement = document.getElementById("card-" + cardId);
            
            // Kartın taşınacağı yeni sütunun gövdesini (body) bul
            var targetColumn = document.getElementById("column-" + newColumnId);

            // Eğer kart ve hedef sütun ekranda varsa (DOM'da bulunuyorsa), kartı yeni yerine ekle
            if (cardElement && targetColumn) {
                targetColumn.appendChild(cardElement);
            }
        });

        // Bağlantıyı başlat ve odaya (Projeye) katıl
        connection.start().then(function () {
            console.log("SignalR Bağlandı. Proje ID odasına giriliyor: " + projectId);
            connection.invoke("JoinProjectGroup", projectId);
        }).catch(function (err) {
            return console.error(err.toString());
        });
    </script>
}