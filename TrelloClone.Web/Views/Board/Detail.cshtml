@using TrelloClone.Core.Entities
@model TrelloClone.Core.Entities.Project

@{
    ViewData["Title"] = Model.Name + " Panosu";
}

<div class="container-fluid mt-4">
    <h2 class="mb-4">@Model.Name</h2>

    <div class="row">
        
        <div class="col-lg-9 mb-4">
            <div class="d-flex overflow-auto" style="gap: 1.5rem; padding-bottom: 1rem; align-items: flex-start;">
                @if(Model.Columns != null)
                {
                    foreach (var column in Model.Columns.OrderBy(c => c.Order))
                    {
                        <div class="card bg-light border-0 shadow-sm" style="min-width: 320px; width: 320px;"
                             ondragover="allowDrop(event)" 
                             ondrop="drop(event, @column.Id)">
                            
                            <div class="card-header bg-transparent border-bottom-0 fw-bold pt-3 pb-1">
                                @column.Title
                            </div>
                            
                            <div class="card-body" id="column-@column.Id" style="min-height: 200px;">
                                @if(column.Cards != null)
                                {
                                    foreach (var card in column.Cards.OrderBy(c => c.Order))
                                    {
                                        <div class="card mb-2 shadow-sm border-0" 
                                             id="card-@card.Id" 
                                             draggable="true" 
                                             ondragstart="drag(event, @card.Id)"
                                             style="cursor: grab;">
                                            <div class="card-body p-3">
                                                <h6 class="card-title mb-1">@card.Title</h6>
                                                <small class="text-muted">@card.Description</small>
                                            </div>
                                        </div>
                                    }
                                }
                            </div>
                            <div class="card-footer bg-transparent border-top-0">
                                <a href="/Board/CreateCard?columnId=@column.Id" class="btn btn-sm btn-outline-secondary w-100">+ Yeni Kart Ekle</a>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>

        <div class="col-lg-3">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white border-bottom-0 pt-3">
                    <h5 class="mb-0 text-muted"><i class="bi bi-clock-history"></i> Son Hareketler</h5>
                </div>
                <div class="card-body p-0">
                    <ul class="list-group list-group-flush">
                        @{
                            var logs = ViewBag.RecentLogs as IEnumerable<AuditLog>;
                        }
                        
                        @if (logs != null && logs.Any())
                        {
                            foreach (var log in logs)
                            {
                                <li class="list-group-item border-0 border-bottom">
                                    <strong class="text-dark">@log.Username</strong> 
                                    <span class="badge bg-primary text-white mx-1" style="font-size: 0.75rem;">@log.Action</span>
                                    <br />
                                    <small class="text-muted" style="font-size: 0.8rem;">@log.CreatedDate.ToString("dd MMM HH:mm")</small>
                                    <p class="text-secondary mt-1 mb-0" style="font-size: 0.85rem;">@log.Details</p>
                                </li>
                            }
                        }
                        else
                        {
                            <li class="list-group-item text-muted border-0 text-center py-4">
                                <small>Henüz bir hareket bulunmuyor.</small>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <script>
        function allowDrop(ev) { ev.preventDefault(); }
        
        function drag(ev, cardId) { ev.dataTransfer.setData("cardId", cardId); }
        
        function drop(ev, newColumnId) {
            ev.preventDefault();
            var cardId = ev.dataTransfer.getData("cardId");
            var cardElement = document.getElementById("card-" + cardId);
            var dropTarget = ev.target.closest('.card-body');
            
            if(dropTarget) { dropTarget.appendChild(cardElement); }

            fetch('/Board/UpdateCardPosition', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ cardId: parseInt(cardId), newColumnId: newColumnId })
            })
            .then(response => { if(!response.ok) alert("Hata oluştu!"); })
            .catch(error => console.error('Hata:', error));
        }

        // SignalR
        var projectId = "@Model.Id"; 
        var connection = new signalR.HubConnectionBuilder().withUrl("/boardHub").build();

        connection.on("ReceiveCardMove", function (cardId, newColumnId) {
            var cardElement = document.getElementById("card-" + cardId);
            var targetColumn = document.getElementById("column-" + newColumnId);
            if (cardElement && targetColumn) { targetColumn.appendChild(cardElement); }
        });

        connection.start().then(function () {
            connection.invoke("JoinProjectGroup", projectId);
        });
    </script>
}